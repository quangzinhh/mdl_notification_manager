<div class="local-notification-dashboard" id="local-notification-dashboard">
    <div class="card mb-4">
        <div class="card-header">
            <h4>{{{str.dashboardtitle}}}</h4>
        </div>
        <div class="card-body">
            <form id="notification-manager-args" method="get" action="index.php" class="row">
                <input type="hidden" name="userid" id="form-userid" value="{{userid}}">
                
                <div class="col-md-4 mb-3">
                    <label for="nm-user-label">{{str.searchusers}}</label>
                    <input type="text" id="nm-user-label" name="userlabel" class="form-control nm-user-input" required="required" placeholder="{{str.searchusers}}" value="{{userlabel}}" list="nm-user-suggestions" autocomplete="off">
                    <datalist id="nm-user-suggestions"></datalist>
                </div>
                
                {{#is_user_selected}}
                <div class="col-md-3 mb-3">
                    <label for="filter-status">Filter</label>
                    <select name="filter" id="filter-status" class="form-control" onchange="document.getElementById('notification-manager-args').submit();">
                        <option value="all" {{#filter_all_selected}}selected{{/filter_all_selected}}>{{str.filter_all}}</option>
                        <option value="read" {{#filter_read_selected}}selected{{/filter_read_selected}}>{{str.filter_read}}</option>
                        <option value="unread" {{#filter_unread_selected}}selected{{/filter_unread_selected}}>{{str.filter_unread}}</option>
                    </select>
                </div>
                
                <div class="col-md-5 mb-3">
                    <label for="search-input">{{str.search}}</label>
                    <div class="input-group">
                        <input type="text" name="search" id="search-input" class="form-control" value="{{search}}">
                        <div class="input-group-append">
                            <button class="btn btn-primary" type="submit">{{str.search}}</button>
                        </div>
                    </div>
                </div>
                {{/is_user_selected}}
            </form>
        </div>
    </div>

    {{#is_user_selected}}
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>{{notificationsfor}}</span>
            <button class="btn btn-danger" id="nm-btn-delete" disabled>
                {{str.delete_selected}}
            </button>
        </div>
        <div class="card-body p-0">
            {{#has_notifications}}
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0" id="nm-notification-table">
                        <thead>
                            <tr>
                                <th style="width: 40px">
                                    <input type="checkbox" id="nm-check-all" title="{{str.select_all}}">
                                </th>
                                <th>{{str.col_subject}}</th>
                                <th>{{str.col_message}}</th>
                                <th>{{str.col_component}}</th>
                                <th>{{str.col_timecreated}}</th>
                                <th>{{str.col_timeread}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#notifications}}
                                <tr class="{{^is_read}}table-warning{{/is_read}}">
                                    <td>
                                        <input type="checkbox" class="nm-check-item" value="{{id}}">
                                    </td>
                                    <td>{{{subject}}}</td>
                                    <td>{{{message}}}</td>
                                    <td>{{component}}</td>
                                    <td>{{timecreated}}</td>
                                    <td>{{timeread}}</td>
                                </tr>
                            {{/notifications}}
                        </tbody>
                    </table>
                </div>
                <div class="p-3 border-top">
                    {{{pagingbar}}}
                </div>
            {{/has_notifications}}
            
            {{^has_notifications}}
                <div class="p-3">
                    <div class="alert alert-info mb-0">{{str.no_notifications}}</div>
                </div>
            {{/has_notifications}}
        </div>
    </div>
    {{/is_user_selected}}

    {{^is_user_selected}}
        <div class="alert alert-info">
            {{str.pleaseselectuser}}
        </div>
    {{/is_user_selected}}
</div>

{{#js}}
require(['local_notification_manager/main'], function(Main) {
    Main.init({
        userid: {{userid}},
        sesskey: '{{sesskey}}'
    });
});
{{/js}}
