{{!
    @template local_notification_manager/trash

    Trash view template.

    @copyright 2024 Developer
    @license http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="local-notification-trash" id="local-notification-trash">
    <div class="card mb-4">
        <div class="card-header">
            <h4>{{{str.tab_trash}}}</h4>
        </div>
        <div class="card-body">
            <form id="notification-manager-args" method="get" action="trash.php" class="row">
                <input type="hidden" name="userid" id="form-userid" value="{{userid}}">
                
                <div class="col-md-4 mb-3">
                    <label for="nm-user-label">{{str.searchusers}}</label>
                    <input type="text" id="nm-user-label" name="userlabel" class="form-control nm-user-input" placeholder="{{str.searchusers}}" value="{{userlabel}}" list="nm-user-suggestions" autocomplete="off">
                    <datalist id="nm-user-suggestions"></datalist>
                </div>
                
                <div class="col-md-8 mb-3">
                    <label for="search-input">{{str.search}}</label>
                    <div class="input-group">
                        <input type="text" name="search" id="search-input" class="form-control" value="{{search}}">
                        <div class="input-group-append">
                            <button class="btn btn-primary" type="submit">{{str.search}}</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-warning">
        <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
            <span>{{notificationsfor}}</span>
            <div>
                <button class="btn btn-success mr-2" id="nm-btn-restore" disabled>
                    <i class="fa fa-undo"></i> {{str.restore_selected}}
                </button>
                <button class="btn btn-danger" id="nm-btn-hard-delete" disabled>
                    <i class="fa fa-times-circle"></i> {{str.delete_selected_permanently}}
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            {{#has_notifications}}
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0" id="nm-trash-table">
                        <thead>
                            <tr>
                                <th style="width: 40px">
                                    <input type="checkbox" id="nm-check-all" title="{{str.select_all}}">
                                </th>
                                <th>User</th>
                                <th>{{str.col_subject}}</th>
                                <th>{{str.col_message}}</th>
                                <th>{{str.col_component}}</th>
                                <th>{{str.col_timedeleted}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#notifications}}
                                <tr>
                                    <td>
                                        <input type="checkbox" class="nm-check-item" value="{{id}}">
                                    </td>
                                    <td>{{username}}</td>
                                    <td>{{{subject}}}</td>
                                    <td>{{{message}}}</td>
                                    <td>{{component}}</td>
                                    <td class="text-danger">{{timedeleted}}</td>
                                </tr>
                            {{/notifications}}
                        </tbody>
                    </table>
                </div>
                <div class="p-3 border-top">
                    {{{pagingbar}}}
                </div>
            {{/has_notifications}}
            
            {{^has_notifications}}
                <div class="p-3">
                    <div class="alert alert-info mb-0">{{str.no_trash_notifications}}</div>
                </div>
            {{/has_notifications}}
        </div>
    </div>
</div>

{{#js}}
require(['local_notification_manager/trash'], function(Trash) {
    Trash.init({
        userid: {{userid}},
        sesskey: '{{sesskey}}'
    });
});
{{/js}}
